# ============================================================
#  MarketMax — environment configuration
# ============================================================
# Copy this file to ".env" and fill in your keys.
#   cp .env.example .env
#
# By DEFAULT the app runs in MOCK MODE (realistic fake data),
# so it works out of the box with no keys.
# Set REACT_APP_USE_MOCK=false to call the real APIs below.
# ------------------------------------------------------------

# Master switch for the PAID apis below (RapidAPI Amazon + DataForSEO keywords).
# "true" = fake data (default). "false" = real APIs.
REACT_APP_USE_MOCK=true

# ------------------------------------------------------------
#  FREE sources need NO keys and turn on automatically:
#    • Google Trends   (Dashboard, Trends)
#    • Reddit FBA buzz (Dashboard, Sidebar)
#    • Amazon Best Sellers scrape (Best Sellers)
#    • Ollama AI assistant (Assistant)
#  They run through the built-in dev proxy (see vite.proxy.js) and
#  fall back to mock data whenever a source is blocked/offline.
#
#  Ollama: install + `ollama pull mistral`, then start it allowing
#  this app:   OLLAMA_ORIGINS=* ollama serve
# ------------------------------------------------------------

# ============================================================
#  Supabase — user accounts + cross-device sync (OPTIONAL)
# ============================================================
# Leave EMPTY to run in "guest mode" (no login, data in localStorage).
# Fill both to enable signup/login, protected dashboard, and synced
# Saved products + Kanban board. See the README "Setup Supabase (5 min)".
#   Project settings → API → Project URL + anon public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# --- RapidAPI: "Real-Time Amazon Data" (Product search & competitors) ---
# 1. Create a free account: https://rapidapi.com
# 2. Subscribe (free Basic plan): https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
# 3. Copy your X-RapidAPI-Key below.
REACT_APP_RAPIDAPI_KEY=
REACT_APP_RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com

# Amazon marketplace country code (US, FR, DE, UK, ...)
REACT_APP_COUNTRY=US

# --- DataForSEO: keyword research (search volume, CPC, competition) ---
# Free trial credits: https://dataforseo.com  (Login + Password = Basic auth)
# NOTE: DataForSEO is a server-to-server API and usually blocks direct
# browser calls (CORS). For real keyword data you may need a small proxy.
# Mock mode is recommended for keyword exploration.
REACT_APP_DATAFORSEO_LOGIN=
REACT_APP_DATAFORSEO_PASSWORD=
